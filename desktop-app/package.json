{
  "name": "junkshop-pos",
  "version": "1.0.0",
  "description": "Offline-first POS system for junkshops",
  "main": "electron/main.js",
  "scripts": {
    "vite:dev": "vite",
    "electron:dev": "wait-on http://localhost:3001 && electron .",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "vite build",
    "dist:win": "vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.joenil.junkshop.pos",
    "productName": "Junkshop POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "services/**/*",
      "database/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "database/",
        "to": "database/"
      }
    ]
  },
  "keywords": [
    "pos",
    "junkshop",
    "electron",
    "react",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "node-machine-id": "^1.1.12",
    "node-thermal-printer": "^4.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "sqlite3": "^6.0.1",
    "sweetalert2": "^11.26.24",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
